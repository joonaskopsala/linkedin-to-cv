{
  "manifest_version": 3,
  "name": "LinkedIn to CV Builder",
  "version": "2.0.0",
  "description": "Upload your LinkedIn PDF export and generate a polished, printable CV.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "downloads", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_title": "LinkedIn to CV",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdf.worker.min.mjs", "vendor/pdf.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-to-cv@extension",
      "strict_min_version": "109.0"
    }
  }
}
